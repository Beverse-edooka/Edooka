# =============================================================================
# Copy to `.env.local` in this folder (edooka/). Never commit real secrets.
# Restart `npm run dev` after changes.
# =============================================================================

# Public origin for verify links + certificate QR codes. MUST be your public
# domain in production (e.g. https://edooka.in) so phones can scan the QR.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Cashfree (leave keys empty for demo checkout) ---
# DEMO = skip Cashfree and redirect to /success?demo=1
# SANDBOX / TEST = sandbox.cashfree.com with TEST… app id
# PRODUCTION = api.cashfree.com with live keys
NEXT_PUBLIC_CASHFREE_MODE=DEMO
# EDOOKA_DEMO_PAYMENTS=1
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_WEBHOOK_SECRET=

# --- PostgreSQL / Neon (Drizzle uses DATABASE_URL only) ---
# For Neon: use the *pooled* connection string (host includes `-pooler`) to cut 2–3s latency on API routes.
# Local: `docker compose up -d` in this folder, then:
#   DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/edooka
# Supabase: Settings → Database → copy "Connection string" (URI). Encode @ in password as %40.
# If seed/db:push fails with getaddrinfo ENOTFOUND: wrong host, DNS/VPN, or use pooler URI from Supabase.
# Direct db.*.supabase.co is often IPv6-only; this app rewrites to a literal IP when your Node supports dns.resolve6Sync.
# Run: npm run db:diag
DATABASE_URL=

# Optional: admin uses .local/admin-catalog.json only (no DB)
# EDOOKA_ADMIN_FILE_ONLY=1

# --- Admin ---
ADMIN_INITIAL_EMAIL=admin@edooka.com
ADMIN_INITIAL_PASSWORD=change-me-in-production
# ADMIN_SESSION_SECRET=

# --- Gmail (certificate email — free with Google App Password) ---
# 1. Enable 2-Step Verification on your Google account
# 2. Create App Password: https://myaccount.google.com/apppasswords
# 3. Use that 16-char password as GMAIL_APP_PASSWORD (not your normal Gmail password)
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=
GMAIL_FROM=your@gmail.com

# --- Resend (optional legacy; certificate email uses Gmail when configured) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=certificates@edooka.in

# --- Supabase (optional: Storage + client Auth; DB still uses DATABASE_URL) ---
# Dashboard → Settings → API: Project URL + anon (publishable) + service_role (server only).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Storage: Dashboard → Storage → New bucket (e.g. edooka-files). Server uploads use service role.
# SUPABASE_STORAGE_BUCKET=edooka-files

PABBLY_WEBHOOK_SECRET=
INTERAKT_API_KEY=
